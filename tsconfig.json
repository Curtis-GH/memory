{
  "compilerOptions": {
    /* Sprache & Zielumgebung */
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],

    /* Module & Auflösung */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,

    /* Typprüfung */
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    /* Sonstiges */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
